<!DOCTYPE html>
<html>
<head>
<title>Monitoring System</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>

body{
    margin:0;
    font-family: 'Segoe UI', sans-serif;
    background:#0f172a;
    color:white;
}

/* HEADER */
.header{
    padding:20px;
    text-align:center;
    background: linear-gradient(90deg,#0ea5e9,#2563eb);
    font-size:22px;
    font-weight:bold;
}

/* CONTAINER */
.container{
    max-width:900px;
    margin:auto;
    padding:20px;
}

/* SEARCH */
.search-box{
    display:flex;
    gap:10px;
    margin-bottom:20px;
}

input{
    flex:1;
    padding:14px;
    border-radius:10px;
    border:none;
    font-size:16px;
}

button{
    padding:14px 20px;
    border:none;
    border-radius:10px;
    background:#2563eb;
    color:white;
    font-weight:bold;
    cursor:pointer;
}

/* CARD */
.card{
    background:#1e293b;
    padding:20px;
    margin-bottom:15px;
    border-radius:12px;
    box-shadow:0 5px 15px rgba(0,0,0,0.3);
}

/* FIELD */
.field{
    margin-bottom:10px;
}

.label{
    font-size:12px;
    color:#94a3b8;
}

.value{
    font-size:15px;
    font-weight:bold;
}

.loading{
    text-align:center;
    margin-top:20px;
}

</style>
</head>

<body>

<div class="header">
Monitoring System
</div>

<div class="container">

<div class="search-box">
<input type="text" id="search" placeholder="Masukkan KEY (Kolom A)...">
<button onclick="searchData()">Search</button>
</div>

<div id="loading" class="loading">Loading data...</div>
<div id="output"></div>

</div>

<script>

const url="https://opensheet.elk.sh/1pNRYXT72zR8TVWw40r26Ag9p7BDvGD8HzW09cKpE6QU/MONITORING";

let data=[];

fetch(url)
.then(res=>res.json())
.then(json=>{
    data=json;
    document.getElementById("loading").style.display="none";
});

document.getElementById("search").addEventListener("keypress",function(e){
    if(e.key==="Enter") searchData();
});

function searchData(){

const keyword=document.getElementById("search").value.toLowerCase().trim();

const results=data.filter(row=>
row["KEY"] && row["KEY"].toLowerCase().includes(keyword)
);

const output=document.getElementById("output");

if(results.length===0){
    output.innerHTML="<div class='card'>Data tidak ditemukan</div>";
    return;
}

let html="";

results.forEach(row=>{

const headers=Object.keys(row);

html+="<div class='card'>";

/* mulai dari kolom B (index 1) sampai V */
for(let i=1;i<=21;i++){

if(headers[i]){

html+=`
<div class="field">
<div class="label">${headers[i]}</div>
<div class="value">${row[headers[i]]}</div>
</div>
`;

}

}

html+="</div>";

});

output.innerHTML=html;

}

</script>

</body>
</html>
